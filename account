# 示例文件：复制为 .account 后再填写真实值
# 用法：cp account .account
# 说明：键名大小写不敏感，等号右侧直接填值，不要加引号

# [scan/analysis 必填] 浙大统一认证账号密码
USERNAME=your_zju_username
PASSWORD=your_zju_password

# [analysis/mic-listen 实时分析必填，二选一]
# OpenAI 官方 Key
OPENAI_API_KEY=your_openai_api_key
# 或 AIHubMix 网关 Key
# AIHUBMIX_API_KEY=your_aihubmix_api_key

# [可选] GLM 系列模型 Key（当 --rt-model 以 glm- 开头时自动使用）
# 建议填写该键（主键名）
# ZAI_API_KEY=your_zai_api_key
# 兼容别名（两者填一个即可）
# GLM_API_KEY=your_glm_api_key

# [可选] OpenAI 兼容网关地址
# - 如果只填 AIHUBMIX_API_KEY 且不填该项，默认会使用 https://aihubmix.com/v1
OPENAI_BASE_URL=https://aihubmix.com/v1

# [stream 模式必填] DashScope 实时 ASR Key
DASHSCOPE_API_KEY=your_dashscope_api_key

# [开启 --rt-dingtalk-enabled 时必填] 钉钉机器人配置
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_token
DINGTALK_SECRET=SECxxxxxxxxxxxxxxxxxxxxxxxx

# [开启 --tingwu-enabled 时必填] 通义听悟 + OSS 配置（仅支持以下标准键名）
ALIBABA_CLOUD_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
TINGWU_APP_KEY=your_tingwu_app_key
TINGWU_OSS_BUCKET=your_oss_bucket
TINGWU_OSS_REGION=cn-beijing
TINGWU_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
